# Local development fallback
DB_FILE_NAME=file:local.db

# Cloud database (Turso/libSQL). Fill these in production.
TURSO_DATABASE_URL=libsql://your-database-your-org.turso.io
TURSO_AUTH_TOKEN=replace-with-turso-auth-token

BETTER_AUTH_SECRET=replace-with-a-long-random-secret
BETTER_AUTH_URL=http://localhost:3001
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=replace-with-google-maps-api-key

# Real payments. Register merchant first, then fill these in Vercel.
PAYMENT_PROVIDER=xendit
XENDIT_SECRET_KEY=replace-with-xendit-production-secret-key
XENDIT_CALLBACK_TOKEN=replace-with-xendit-callback-token

# Production uploads. Required before storing profile photos, proof images,
# promo media, chat photos, and custom ringtones at real scale.
CLOUDINARY_CLOUD_NAME=replace-with-cloudinary-cloud-name
CLOUDINARY_API_KEY=replace-with-cloudinary-api-key
CLOUDINARY_API_SECRET=replace-with-cloudinary-api-secret

# Alternative upload/backup storage: AWS S3 or Cloudflare R2-compatible.
# Set UPLOAD_PROVIDER=s3 to prefer this storage over Cloudinary.
UPLOAD_PROVIDER=cloudinary
S3_BUCKET=replace-with-bucket
S3_REGION=auto
S3_ACCESS_KEY_ID=replace-with-access-key
S3_SECRET_ACCESS_KEY=replace-with-secret-key
S3_ENDPOINT=https://replace-with-account.r2.cloudflarestorage.com
S3_PUBLIC_BASE_URL=https://cdn.serjafan.id
BACKUP_TO_OBJECT_STORAGE=0

# Web push notification keys.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=replace-with-vapid-public-key
VAPID_PRIVATE_KEY=replace-with-vapid-private-key
VAPID_SUBJECT=mailto:support@serjafan.id

# Optional but recommended for Vercel Cron endpoint protection.
CRON_SECRET=replace-with-long-random-cron-secret
